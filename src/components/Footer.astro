---
const year = new Date().getFullYear();
---

<footer class="footer">
	<div class="container footer-inner">
		<p class="meta">&copy; {year} Brandon DeVere</p>
		<div class="footer-links">
			<a href="mailto:hello@brandondevere.com">Email</a>
			<a href="https://www.linkedin.com/in/brandondevere" target="_blank" rel="noopener noreferrer">LinkedIn</a>
		</div>
	</div>
</footer>

<style>
	.footer {
		border-top: 1px solid var(--color-border);
		margin-top: var(--section-gap);
	}

	.footer-inner {
		display: flex;
		align-items: center;
		justify-content: space-between;
		padding-block: var(--space-lg);
	}

	.footer-links {
		display: flex;
		gap: var(--space-md);
	}

	.footer-links a {
		font-size: 0.875rem;
		text-decoration: none;
	}
</style>
